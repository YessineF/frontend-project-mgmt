{
  "buildCommand": "npm install && npx ng build --configuration production",
  "outputDirectory": "dist/frontend-project-mgmt/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-project-mgmt-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
